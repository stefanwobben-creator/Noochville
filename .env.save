openalex_mailto=stefanwobben@gmail.com
OPENALEX_API_KEY=jqS2n9WgF4WONQiQSooO9U

# ── Google Trends geo ────────────$
# Skill: google_trends  |  GrowthAnalyst haalt trending zoekopdrachten op.
# ISO 3166-1 alpha-2 landcode. Meerdere landen: komma-gescheiden (NL,BE).
# Leeglaten = wereldwijd.
trends_geo=


# ── Tijdsintervallen (optioneel, voor demo/test) ────────────────────────────────
# In productie weglaten — de defaults zijn dan van kracht.
# Op 0 zetten = altijd triggeren bij elke puls (handig tijdens ontwikkeling).

# Hartslag van de TimeKeeper in seconden (default: 86400 = 1 dag)
# heartbeat_seconds=86400

# Interval voor de TijdgeestWachter in seconden (default: 604800 = 1 week)
# tijdgeest_interval_seconds=604800

# Interval voor periodieke reflectie per inwoner (default: 604800 = 1 week)
# reflect_interval_seconds=604800

KEYWORDS_EVERYWHERE_API_KEY=ee5675ae6e04736b5597

SERPAPI_API_KEY=ee5675ae6e04736b5597

grounding_batch_size=6
LLM_MAX_PER_MINUTE=5
