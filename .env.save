# .env.example — NoochVillage
# Kopieer naar .env en vul de waarden in. Het .env-bestand mag NOOIT worden gecommit.
# config.py laadt dit bestand in context.settings én os.environ.
# Optionele waarden kun je weglaten of leeg laten; de skill werkt dan in beperkte modus.


# ── LLM-redenering (optioneel) ─────────────────────────────────────────────────
# Zonder key valt het dorp terug op heuristieke redenering (geen LLM-oproepen).
# Kies één van beide; Anthropic heeft prioriteit als beide aanwezig zijn.

# Anthropic — https://console.anthropic.com → API keys → Create key
ANTHROPIC_API_KEY=sk-ant-api03-U5_EAq63tSA-ho484Pahs-c_H29E-G4hU48fyTwU-cbAahZEqQr4XLPjYDVK7_XdPs74oZaFJspjKMT1w2CqdQAA

# Google Gemini — https://aistudio.google.com/app/apikey → Get API key
# Alternatief: GOOGLE_API_KEY werkt ook (llm.py leest beide).
GEMINI_API_KEY=AIzaSyARSKRDNaTEwqcNll2-6-Ucb3ESJCciYmA


# ── Plausible Analytics ─────────────────────────────────────────────────────────
# Skill: plausible_stats  |  GrowthAnalyst gebruikt dit voor de dagelijkse groeipuls.

# API-sleutel — Plausible dashboard → Settings → API keys → New API key
PLAUSIBLE_API_KEY=CBAYlUoHm23Q0Ja7ien5ZkRLcVwVm3VXHCOMz3U-45UUef7ItFSLqUfHsbQKkE79

# Site-id zoals geregistreerd in Plausible (bv. nooch.earth)
# Plausible dashboard → je site → Settings → bovenaan "Site domain"
PLAUSIBLE_SITE_ID=nooch.earth


# ── Google Search Console ───────────────────────────────────────────────────────
# Skill: gsc_performance  |  PerformanceScout haalt query-data op (last 28 days).
#
# Stap 1 — OAuth-credentials ophalen:
#   Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
#   → Download JSON → sla op als client_secret.json (staat in .gitignore)
#
# Stap 2 — Token genereren (eenmalig interactief):
#   python -c "
#   from google_auth_oauthlib.flow import InstalledAppFlow
#   flow = InstalledAppFlow.from_client_secrets_file('client_secret.json',
#            ['https://www.googleapis.com/auth/webmasters.readonly'])
#   creds = flow.run_local_server(port=0)
#   open('gsc_token.json', 'w').write(creds.to_json())"

# Pad naar het gegenereerde OAuth-token (relatief aan de projectmap of absoluut)
GSC_TOKEN_PATH=./gsc_token.json

# GSC-site-identifier — Search Console → kies property → kopieer de URL bovenaan
# Domein-property:  sc-domain:nooch.earth
# URL-prefix:       https://nooch.earth/
GSC_SITE=sc-domain:nooch.earth


# ── Semantic Scholar ────────────────────────────────────────────────────────────
# Skill: semscholar_tldr  |  KennisScout grondt lexicon-termen in wetenschappelijke papers.
# Zonder key: ~100 req / 5 min (voldoende voor normaal gebruik, backoff ingebouwd).
# Met key: hogere limieten — https://www.semanticscholar.org/product/api → Get API Key
SEMANTIC_SCHOLAR_API_KEY=s2k-aEPQyMJYAoz4TpRzPrs7JRxc8X6tgxFrpWTx2ki7


# ── OpenAlex ────────────────────────────────────────────────────────────────────
# Skill: openalex_evidence  |  KennisScout haalt academische werken op.
# API-key vereist (usage-based, gratis tier — bijgehouden per 13-02-2026).
