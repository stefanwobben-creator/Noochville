# .env.example — NoochVillage
# Kopieer naar .env en vul de waarden in. Het .env-bestand mag NOOIT worden gecommit.
# config.py laadt dit bestand in context.settings én os.environ.
# Optionele waarden kun je weglaten of leeg laten; de skill werkt dan in beperkte modus.


# ── LLM-redenering (optioneel) ─────────────────────────────────────────────────
# Zonder werkende trede valt het dorp terug op heuristiek (fail-closed, geen LLM).
# De ladder loopt van goedkoop naar duur en stopt bij de eerste trede die antwoordt.
# Volgorde = vendor:model, komma-gescheiden. Een trede zonder sleutel wordt overgeslagen.
LLM_LADDER=mistral:mistral-small-latest,gemini:gemini-2.5-flash-lite,gemini:gemini-2.5-flash,anthropic:claude-haiku-4-5-20251001

# Hoelang een uitgeputte trede (rate-limit/dagcap) wordt overgeslagen, in seconden. Default 1800 (30 min).
LLM_TIER_COOLDOWN_S=1800

# Anthropic — https://console.anthropic.com → API keys → Create key
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey → Get API key
# Alternatief: GOOGLE_API_KEY werkt ook (llm.py leest beide).
GEMINI_API_KEY=

# Mistral — https://console.mistral.ai → API Keys (gratis tier; activeert de 2e trede)
MISTRAL_API_KEY=
# Optioneel: overschrijf het model (default mistral-small-latest)
MISTRAL_MODEL=


# ── Plausible Analytics ─────────────────────────────────────────────────────────
# Skill: plausible_stats  |  GrowthAnalyst gebruikt dit voor de dagelijkse groeipuls.

# API-sleutel — Plausible dashboard → Settings → API keys → New API key
PLAUSIBLE_API_KEY=

# Site-id zoals geregistreerd in Plausible (bv. nooch.earth)
# Plausible dashboard → je site → Settings → bovenaan "Site domain"
PLAUSIBLE_SITE_ID=nooch.earth


# ── Google Search Console ───────────────────────────────────────────────────────
# Skill: gsc_performance  |  PerformanceScout haalt query-data op (last 28 days).
#
# Stap 1 — OAuth-credentials ophalen:
#   Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
#   → Download JSON → sla op als client_secret.json (staat in .gitignore)
#
# Stap 2 — Token genereren (eenmalig interactief):
#   python -c "
#   from google_auth_oauthlib.flow import InstalledAppFlow
#   flow = InstalledAppFlow.from_client_secrets_file('client_secret.json',
#            ['https://www.googleapis.com/auth/webmasters.readonly'])
#   creds = flow.run_local_server(port=0)
#   open('gsc_token.json', 'w').write(creds.to_json())"

# Pad naar het gegenereerde OAuth-token (relatief aan de projectmap of absoluut)
GSC_TOKEN_PATH=./gsc_token.json

# GSC-site-identifier — Search Console → kies property → kopieer de URL bovenaan
# Domein-property:  sc-domain:nooch.earth
# URL-prefix:       https://nooch.earth/
GSC_SITE=sc-domain:nooch.earth


# ── Semantic Scholar ────────────────────────────────────────────────────────────
# Skill: semscholar_tldr  |  KennisScout grondt lexicon-termen in wetenschappelijke papers.
# Zonder key: ~100 req / 5 min (voldoende voor normaal gebruik, backoff ingebouwd).
# Met key: hogere limieten — https://www.semanticscholar.org/product/api → Get API Key
SEMANTIC_SCHOLAR_API_KEY=


# ── OpenAlex ────────────────────────────────────────────────────────────────────
# Skill: openalex_evidence  |  KennisScout haalt academische werken op (keyless).
# Polite pool: hogere rate-limit als je een geldig e-mailadres opgeeft.
# Geen registratie nodig — gewoon je eigen adres invullen.
openalex_mailto=jouw@emailadres.nl


# ── Google Trends geo ───────────────────────────────────────────────────────────
# Skill: google_trends  |  GrowthAnalyst haalt trending zoekopdrachten op.
# ISO 3166-1 alpha-2 landcode. Meerdere landen: komma-gescheiden (NL,BE).
# Leeglaten = wereldwijd.
trends_geo=NL


# ── Tijdsintervallen (optioneel, voor demo/test) ────────────────────────────────
# In productie weglaten — de defaults zijn dan van kracht.
# Op 0 zetten = altijd triggeren bij elke puls (handig tijdens ontwikkeling).

# Hartslag van de TimeKeeper in seconden (default: 86400 = 1 dag)
# heartbeat_seconds=86400

# Interval voor de TijdgeestWachter in seconden (default: 604800 = 1 week)
# tijdgeest_interval_seconds=604800

# Interval voor periodieke reflectie per inwoner (default: 604800 = 1 week)
# reflect_interval_seconds=604800


# ── Cockpit — bijlage-upload ────────────────────────────────────────────────────
# Max grootte van een projectwall-bijlage. Accepteert '20M'/'20MB'/bytes; default 20M.
# BEWUST onder het nginx-plafond (client_max_body_size 25M in deploy/nginx.conf) zodat de APP de nette
# fout geeft ("bestand te groot, max X MB"), niet nginx (kale 413-pagina).
# upload_max_bytes=20M
